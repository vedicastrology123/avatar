function deepCleanVNode(node) {
    if (!node || typeof node !== 'object') return node;

    // Handle arrays of children
    if (Array.isArray(node)) {
        return node.map(deepCleanVNode);
    }

    if (node.props) {
        // Ensure the style object exists
        node.props.style = node.props.style || {};
        const s = node.props.style;
        const classes = node.props.className || node.props.class || "";

        // 1. MANDATORY DISPLAY FOR SATORI
        // Satori crashes/ignores nodes with multiple children if display isn't explicit
        if (s.display !== 'none') {
            s.display = 'flex';

            // 2. TAILWIND CLASS MAPPING
            // Satori doesn't always pick up layout properties from the external CSS file
            if (classes.includes('flex-row')) s.flexDirection = 'row';
            if (classes.includes('flex-col')) s.flexDirection = 'column';
            if (classes.includes('flex-wrap')) s.flexWrap = 'wrap';
            if (classes.includes('justify-center')) s.justifyContent = 'center';
            if (classes.includes('items-center')) s.alignItems = 'center';
            if (classes.includes('font-bold')) s.fontWeight = 700;

            // 3. ASTROLOGY CHART SPECIFIC FIXES
            // Force dimensions on the Rashi/Navamsa grid and boxes
            if (classes.includes('chart-grid')) {
                s.width = 342;
                s.height = 342;
                s.flexDirection = 'row';
                s.flexWrap = 'wrap';
                s.border = '2px solid #000000';
            }
            
            if (classes.includes('house-box')) {
                s.width = 85;
                s.height = 85;
                s.flexShrink = 0; // Prevent the box from collapsing to 0 width
                s.flexDirection = 'column';
                s.alignItems = 'center';
                s.justifyContent = 'center';
                s.border = '0.5px solid #64748b';
            }

            // 4. TABLE ELEMENT FALLBACKS
            // If it's a standard table tag and doesn't have a direction, set it
            if (!s.flexDirection) {
                const tag = node.type;
                if (tag === 'tr' || tag === 'thead') {
                    s.flexDirection = 'row';
                } else {
                    s.flexDirection = 'column';
                }
            }
        }

        // 5. UNITLESS CONVERSION (The "Panic" Fix)
        // Ensure z-index and weights don't have 'px'
        ['zIndex', 'z-index', 'fontWeight', 'font-weight'].forEach(key => {
            if (s[key] !== undefined) {
                const val = String(s[key]).replace(/[^0-9-]/g, '');
                const targetKey = key.includes('font') ? 'fontWeight' : 'zIndex';
                s[targetKey] = val ? parseInt(val, 10) : (targetKey === 'fontWeight' ? 400 : 0);
                if (key !== targetKey) delete s[key];
            }
        });

        // 6. PREVENT ZERO-DIMENSION COLLAPSE
        // If an element has a border but no content, Resvg might panic or hide it
        if (s.border || s.borderWidth) {
            s.minWidth = s.minWidth || 1;
            s.minHeight = s.minHeight || 1;
        }

        // Recursive call for children
        if (node.props.children) {
            node.props.children = deepCleanVNode(node.props.children);
        }
    }
    return node;
}

function satoriSystemStrip(html) {
    return html
        .replace(/<(script|style)\b[^>]*>([\s\S]*?)<\/\1>/gi, '')
        // Clean the UI "noise"
        .replace(/Emailing Your horoscope\.\.\./g, '')
        .replace(/Sending Email/g, '')
        .replace(/Done/g, '')
        .replace(/Chat to get predictions.*/g, '')
        .replace(/!important/g, '');
}

function prepareNakedHtml(html) {
    if (!html) return '';
    return html
        .replace(/(z-index|zIndex)\s*:\s*(\d+)px/gi, '$1: $2')
        .replace(/\s{2,}/g, ' ')
        .trim();
}

