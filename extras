function deepCleanVNode(node) {
    if (!node || typeof node !== 'object') return node;

    if (Array.isArray(node)) {
        return node.map(child => deepCleanVNode(child));
    }

    if (node.props) {
        const props = node.props;
        
        // 1. CLEAN STYLE OBJECT
        if (props.style && typeof props.style === 'object') {
            const s = props.style;
            
            // Force numeric zIndex (Kill the 50px zombie)
            if (s.zIndex !== undefined) {
                const val = String(s.zIndex).replace(/[^0-9-]/g, '');
                s.zIndex = val ? parseInt(val, 10) : 0;
            }

            // THE PANIC KILLER: Force Flex and absolute stability
if (s.display !== 'none') {
    s.display = 'flex';
    if (!s.flexDirection) s.flexDirection = 'column';
    
    // Ensure every div has at least a minimum "physical" presence
    // Satori sometimes panics if it tries to render a 0-height element with borders
    if (!s.width && !s.flex) s.width = '100%'; 
}
        }

        // 2. THE NUCLEAR STEP: Delete className
        // This stops Satori from re-injecting 50px based on Tailwind names
        if (props.className) {
            delete props.className;
        }

        // 3. RECURSE DEEPLY
        if (props.children) {
            if (Array.isArray(props.children)) {
                props.children = props.children.map(deepCleanVNode);
            } else if (typeof props.children === 'object') {
                props.children = deepCleanVNode(props.children);
            }
        }
    }
    return node;
}



function satoriSystemStrip(html) {
    return html
        .replace(/<(script|style)\b[^>]*>([\s\S]*?)<\/\1>/gi, '')
        .replace(/!important/g, '')
        // Add 'camelcase' to the system-level strip
        .replace(/\b(fixed|camelcase)\b/g, 'absolute') 
        .replace(/position:\s*fixed/gi, 'position: absolute');
}

function prepareNakedHtml(html) {
    if (!html) return '';

    return html
        // AGGRESSIVE Z-INDEX: Catch every variation (with/without spaces, quotes, etc.)
        .replace(/(z-index|zIndex)\s*:\s*['"]?(\d+)px['"]?/gi, '$1: $2')

        // STRIP THE REST OF THE NOISE
        .replace(/\b(inline-block|print-ui-only|sticky|backdrop-blur-[a-z0-9-]+|animate-[a-z-]+|transition-[a-z-]+)\b/gi, '')
        .replace(/\b(gap-\d+|space-[xy]-\d+|grid|cols-\d+|tracking-[a-z-]+)\b/gi, '')
        .replace(/\b[a-z0-9-]+-\[[^\]]+\]/g, '')

        // THE PANIC FIX: Include more tags (span, table, section) to be safe
        .replace(/<(div|section|main|span|table)(?![^>]*style=['"])/gi, '<$1 style="display: flex; flex-direction: column;"')
        .replace(/style=(['"])/gi, 'style=$1display: flex; flex-direction: column; ')

        .replace(/\s{2,}/g, ' ')
        .replace(/z-index:\s*(\d+)px/gi, 'z-index: $1')
        .replace(/font-weight:\s*(\d+)px/gi, 'font-weight: $1')
        .replace(/flex-grow:\s*(\d+)px/gi, 'flex-grow: $1')
        .trim();
}

